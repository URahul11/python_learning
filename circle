##circle sum of square
a=int(input("Enter any number:")) 
nums=[]
while(True):
    if a==1:
        break
    elif a in nums:
        break
    else:
        nums.append(a)
        d=sum([int(i)*int(i)for i in str(a)])# comphrinsion of summing of squares in one line
        nums.append(d)
        a=d
if(a==1):
    print("yes")
else:
    print("no")
