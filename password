a=input("Enter a number:" )
up=0
lo=0
sp=0
dg=0
if len(a)>7:
    for i in a:
        if i.isupper():
            up += 1
        elif i.islower():
            lo+=1
        elif i.isdigit():
            dg+=1
        else:
            sp+=1
    if up>=1 and lo>=1 and dg>=1 and sp>=1:
        print("strong")
    else:
        print("weak")
else:
    print("weak due to lo ch")
